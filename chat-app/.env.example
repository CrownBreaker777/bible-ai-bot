# === AI Model Configuration ===
OPENAI_API_KEY=your_api_key_here

# Model name — change this to switch models
MODEL_NAME=gpt-oss-120b

# If using a custom/alternative API endpoint (e.g. Azure, proxy, etc.)
# Leave as default for standard OpenAI
API_BASE_URL=https://api.openai.com/v1

# === App Configuration ===
PORT=3000

# Optional: customize the AI's personality
SYSTEM_PROMPT=You are a warm, helpful, and intelligent assistant. Be friendly, clear, and concise.
